---
import { getCollection, getEntry } from "astro:content";
import Layout from "@/src/layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = "https://rickyhidayat.com";
const postUrl = `${siteUrl}/blog/${post.slug}`;
const publishedDate = post.data.date.toISOString();

function formatDate(date: Date) {
  return date.toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedDate,
  url: postUrl,
  author: {
    "@type": "Person",
    name: "Ricky Hidayat",
    url: siteUrl,
  },
  publisher: {
    "@type": "Person",
    name: "Ricky Hidayat",
    url: siteUrl,
  },
  keywords: post.data.tags.join(", "),
};
---

<Layout
  locale="id"
  title={`${post.data.title} — Ricky Hidayat`}
  description={post.data.description}
  ogType="article"
  publishedDate={publishedDate}
  keywords={post.data.tags.join(", ")}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <header class="py-4 flex items-center justify-between fixed top-0 left-1/2 -translate-x-1/2 z-50 w-full max-w-2xl px-5 transition-all duration-300 bg-background/70 backdrop-blur-xl border-b border-white/10">
    <div class="flex items-center gap-5">
      <a
        class="opacity-50 transition-all duration-200 hover:opacity-100 text-[0.85rem]"
        href="/blog"
      >
        ← Blog
      </a>
      <span class="opacity-100 text-[0.85rem] font-bold text-green-500">Post</span>
    </div>
  </header>

  <main class="mt-32 pb-24">
    <div class="mb-8">
      <time class="text-[0.78rem] opacity-40 uppercase tracking-wider block mb-2">
        {formatDate(post.data.date)}
      </time>
      <h1 class="text-xl font-semibold mb-3 leading-snug">
        {post.data.title}
      </h1>
      <p class="opacity-50 text-[0.88rem]">{post.data.description}</p>
      <div class="flex gap-2 mt-3 flex-wrap">
        {
          post.data.tags.map((tag) => (
            <span class="text-[0.72rem] uppercase opacity-40 border px-1.5 py-0.5">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    <hr class="opacity-20 mb-8" />

    <article class="prose-blog">
      <Content />
    </article>
  </main>
</Layout>

<style>
  .prose-blog :global(h1),
  .prose-blog :global(h2),
  .prose-blog :global(h3),
  .prose-blog :global(h4) {
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .prose-blog :global(h1) { font-size: 1.25rem; }
  .prose-blog :global(h2) { font-size: 1.1rem; opacity: 0.9; }
  .prose-blog :global(h3) { font-size: 1rem; opacity: 0.8; }

  .prose-blog :global(p) {
    margin-bottom: 1rem;
    opacity: 0.7;
    font-size: 0.9rem;
    line-height: 1.8;
  }

  .prose-blog :global(ul),
  .prose-blog :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    opacity: 0.7;
    font-size: 0.9rem;
  }

  .prose-blog :global(li) {
    margin-bottom: 0.35rem;
    line-height: 1.7;
  }

  .prose-blog :global(ul li) {
    list-style-type: "– ";
  }

  .prose-blog :global(pre) {
    background-color: oklch(18% 0.012 285);
    border: 1px solid oklch(28% 0.016 285);
    border-radius: 0;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .prose-blog :global(code) {
    font-family: inherit;
    font-size: 0.82rem;
    background-color: oklch(20% 0.012 285);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
  }

  .prose-blog :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prose-blog :global(strong) {
    font-weight: 600;
    opacity: 1;
  }

  .prose-blog :global(a) {
    color: oklch(64% 0.18 270);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-blog :global(blockquote) {
    border-left: 2px solid oklch(50% 0.18 142);
    padding-left: 1rem;
    opacity: 0.6;
    font-style: italic;
    margin: 1rem 0;
  }

  .prose-blog :global(hr) {
    opacity: 0.15;
    margin: 2rem 0;
  }
</style>
