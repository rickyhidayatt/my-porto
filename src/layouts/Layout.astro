---
import { PageMetadata } from "@/src/components/hybrid-astro-ui/page-metadata";
import OGImage from "@/src/assets/background.png";

interface Props {
  title: string;
  description: string;
  locale: string;
  alternateLinks?: { href: string; hreflang: string }[];
  /** Override OG type — default "website" */
  ogType?: "website" | "article";
  /** ISO date string for article pages */
  publishedDate?: string;
  /** Keywords for article/blog pages */
  keywords?: string;
}

const {
  title,
  description,
  locale,
  alternateLinks,
  ogType = "website",
  publishedDate,
  keywords,
} = Astro.props as Props;

const siteUrl = "https://rickyhidayat.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = `${siteUrl}${OGImage.src}`;

// JSON-LD Person schema — helps Google understand who you are
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ricky Hidayat",
  url: siteUrl,
  sameAs: [
    "https://github.com/rickyhidayatt",
    "https://www.linkedin.com/in/rickyhytt",
  ],
  jobTitle: "Backend Developer",
  description:
    "Backend Developer with 2.5+ years building scalable, high-concurrency systems in Go for core banking and fintech.",
  knowsAbout: ["Golang", "Microservices", "gRPC", "REST API", "PostgreSQL", "Docker"],
};
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <PageMetadata
      lang={locale}
      title={title}
      description={description}
      image={OGImage}
      enableClientRouter
      ogType={ogType}
      favicons={[{ rel: "icon", type: "image/png", href: "/icon.png", sizes: "32x32" }]}
      alternateLinks={alternateLinks}
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <!-- Author & Keywords -->
    <meta name="author" content="Ricky Hidayat" />
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Open Graph extended -->
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ricky Hidayat" />
    <meta property="og:locale" content={locale === "id" ? "id_ID" : "en_US"} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — Ricky Hidayat`} />
    {publishedDate && (
      <meta property="article:published_time" content={publishedDate} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:creator" content="@rickyhytt" />

    <!-- JSON-LD Person Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body class="*:max-w-2xl *:w-full flex flex-col items-center w-full font-mono px-5 md:px-0 leading-7">
    <slot />
  </body>
</html>
